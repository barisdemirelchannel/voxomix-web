# Only real site files should be served publicly. Everything below is dev/build
# tooling, version control, or OS cruft and must never be deployed.

# Version control & tooling
.git
.git/**
.gitignore
.wrangler
.wrangler/**
.claude
.claude/**
.assetsignore

# OS / editor cruft
.DS_Store
**/.DS_Store
Icon?
# AppleDouble sidecars — macOS writes one next to every file on the exFAT SSD
# checkout, so without this every deploy uploads ~45 junk files.
._*
**/._*

# Build config & source (not site assets)
node_modules
node_modules/**
wrangler.toml
package.json
package-lock.json
*.md
